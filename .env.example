APP_NAME=NileShop
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8888

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=nileshop
DB_USERNAME=nileshop
DB_PASSWORD=nileshop_secret

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@nileshop.ss"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=nileshop
AWS_SECRET_ACCESS_KEY=nileshop_secret
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=nileshop
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_URL=http://localhost:8888/media

MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=nileshop_meili_master_key

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,localhost:8888,127.0.0.1

# Docker host ports (change if already in use on your machine)
NGINX_PORT=8888
VITE_API_URL=http://localhost:8888/api/v1
MINIO_PORT=9002
MINIO_CONSOLE_PORT=9003
MAILPIT_SMTP_PORT=1026
MAILPIT_UI_PORT=8026

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/api/v1/auth/social/google/callback"

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI="${APP_URL}/api/v1/auth/social/facebook/callback"

OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5

SMS_DRIVER=log
AFRICAS_TALKING_API_KEY=
AFRICAS_TALKING_USERNAME=

FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=

STRIPE_KEY=
STRIPE_SECRET=
FCM_SERVER_KEY=


