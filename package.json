{
  "name": "nileshop",
  "version": "1.0.0",
  "private": true,
  "description": "NileShop — Multi-Vendor E-Commerce Marketplace for South Sudan",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:web:local": "cd apps/web && npm run dev",
    "dev:mobile:vendor": "cd apps/mobile/vendor && npm start",
    "dev:mobile:delivery": "cd apps/mobile/delivery && npm start",
    "build:web": "npm run build --workspace=apps/web",
    "lint:web": "npm run lint --workspace=apps/web",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:build": "docker compose build",
    "docker:logs": "docker compose logs -f"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
